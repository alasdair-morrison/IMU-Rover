#define whB_A 50 // Wheel B output B
#define whB_B 51 // wheel B output A
#define whC_A 49  // Wheel C output B
#define whC_B 48 // wheel C output A
#define whD_A 46 // wheel D output B
#define whD_B 47 // wheel D output A
#define whE_A 8 // wheel E output B
#define whE_B 7 // wheel E output A
