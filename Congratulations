#define whF_A 42 // wheel F output B 
#define whF_B 43 // wheel F output A

#define PWM_A 35 
#define in1_A 30 
#define in2_A 31 
#define in1_B 32 
#define in2_B 33 
#define PWM_B 37 

#define PWM_C 39 
#define in1_C 26 
#define in2_C 27 
#define in1_D 28 
#define in2_D 29 
